# Production (set in Vercel project env)
VITE_CONTROL_PLANE_URL=https://app.kosmos.computer

# Optional local Kosmos prototype for developers
VITE_DEMO_URL=http://localhost:4610

# Brevo waitlist (server-only — set in Vercel, never prefix with VITE_)
# Use an API key (xkeysib-...), not an SMTP key (xsmtpsib-...).
# List ID: Brevo → Contacts → Lists
BREVO_API_KEY=
BREVO_LIST_ID=
